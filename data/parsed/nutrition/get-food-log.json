{
  "domain": "nutrition",
  "title": "Get Food Log",
  "url": "https://dev.fitbit.com/build/reference/web-api/nutrition/get-food-log/",
  "method": "get",
  "path": "/1/user/{user-id}/foods/log/date/{date}.json",
  "description": "Retrieves a summary of the user's food log entry for a given day.",
  "scope": "nutrition",
  "parameters": [
    {
      "name": "user-id",
      "location": "path",
      "required": true,
      "description": "The encoded ID of the user. Use \"-\" (dash) for current logged-in user."
    },
    {
      "name": "date",
      "location": "path",
      "required": true,
      "description": "The date of records to be returned in the format yyyy-MM-dd."
    }
  ],
  "response_fields": [
    {
      "name": "foods : isFavorite",
      "description": ""
    },
    {
      "name": "foods : logDate",
      "description": ""
    },
    {
      "name": "foods : logId",
      "description": ""
    },
    {
      "name": "foods : loggedFood : accessLevel",
      "description": ""
    },
    {
      "name": "foods : loggedFood : amount",
      "description": ""
    },
    {
      "name": "foods : loggedFood : brand",
      "description": ""
    },
    {
      "name": "foods : loggedFood : calories",
      "description": ""
    },
    {
      "name": "foods : loggedFood : foodId",
      "description": ""
    },
    {
      "name": "foods : loggedFood : locale",
      "description": ""
    },
    {
      "name": "foods : loggedFood : mealTypeId",
      "description": ""
    },
    {
      "name": "foods : loggedFood : name",
      "description": ""
    },
    {
      "name": "foods : loggedFood : unit : id",
      "description": ""
    },
    {
      "name": "foods : loggedFood : unit : name",
      "description": ""
    },
    {
      "name": "foods : loggedFood : unit : plural",
      "description": ""
    },
    {
      "name": "foods : loggedFood : units",
      "description": ""
    },
    {
      "name": "foods : nutritionalValues",
      "description": "Available nutritional values for the food consumed."
    },
    {
      "name": "goals : calories",
      "description": "Daily calories goal."
    }
  ],
  "example_response": {
    "foods": [
