      "description": ""
    },
    {
      "name": "food : foodId",
      "description": ""
    },
    {
      "name": "food : isGeneric",
      "description": ""
    },
    {
      "name": "food : name",
      "description": ""
    },
    {
      "name": "food : nutritionalValues",
      "description": "Available nutritional values for the food consumed."
    },
    {
