{
  "domain": "nutrition",
  "title": "Create Food",
  "url": "https://dev.fitbit.com/build/reference/web-api/nutrition/create-food/",
  "method": "post",
  "path": "/1/user/{user-id}/foods.json",
  "description": "Creates a new private food for a user.",
  "scope": "nutrition",
  "parameters": [
    {
      "name": "user-id",
      "location": "path",
      "required": true,
      "description": "The encoded ID of the user. Use \"-\" (dash) for current logged-in user."
    },
    {
      "name": "defaultFoodMeasurementUnitId",
      "location": "query",
      "required": true,
      "description": "ID representing the default measurement unit used. A full list of units can be retrieved using the Get Food Units endpoints."
    },
    {
      "name": "defaultServingSize",
      "location": "query",
      "required": true,
      "description": "Size of the default serving. Nutritional values should be provided for this serving size."
    },
    {
      "name": "calories",
      "location": "query",
      "required": true,
      "description": "Number of calories for the default serving size."
    },
    {
      "name": "formType",
      "location": "query",
      "required": true,
      "description": "The texture of the food. Supported : LIQUID | DRY"
    },
    {
      "name": "description",
      "location": "query",
      "required": true,
      "description": "Description of the food."
    }
  ],
  "response_fields": [
