{
  "domain": "nutrition",
  "title": "Update Meal",
  "url": "https://dev.fitbit.com/build/reference/web-api/nutrition/update-meal/",
  "method": "post",
  "path": "/1/user/{user-id}/meals/{meal-id}.json",
  "description": "Updates an existing meal with the contents of the request.",
  "scope": "nutrition",
  "parameters": [
    {
      "name": "user-id",
      "location": "path",
      "required": true,
      "description": "The encoded ID of the user. Use \"-\" (dash) for current logged-in user."
    },
    {
      "name": "meal-id",
      "location": "path",
      "required": true,
      "description": "The ID of the meal."
    },
    {
      "name": "description",
      "location": "query",
      "required": true,
      "description": "Short description of the meal."
    },
    {
      "name": "foodId",
      "location": "query",
      "required": true,
      "description": "ID of the food to be included in the meal."
    },
    {
      "name": "unitId",
      "location": "query",
      "required": true,
      "description": "ID of the units used. The units ID can be retrieved through a call to Get Food Logs, Search Foods or Get Food Units."
    },
    {
      "name": "amount",
      "location": "query",
      "required": true,
      "description": "Amount consumed in the format X.XX, in the specified unitId."
    }
  ],
  "response_fields": [
    {
      "name": "meal : description",
      "description": ""
    },
    {
      "name": "meal : id",
      "description": ""
    },
